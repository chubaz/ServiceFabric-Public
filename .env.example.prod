# --- Core Config ---
COMPOSE_PROJECT_NAME=service_fabric_prod
PROXY_PORT=80
DEBUG=0
ALLOWED_HOSTS=yourdomain.com

# --- Django Config ---
SECRET_KEY=production_secret_key_change_me
DJANGO_SECRET_KEY=production_secret_key_change_me

# --- Database Config ---
POSTGRES_DB=servicefabric
POSTGRES_USER=postgres
POSTGRES_PASSWORD=production_db_password_change_me
DATABASE_URL=postgresql://postgres:production_db_password_change_me@db:5432/servicefabric

# --- Superuser Config ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=production_admin_password_change_me

# --- Paths & Services ---
SERVICE_CATALOG_PATH=/app/services_catalog
STATIC_ASSETS_PATH=/app/flask_static
FLASK_SERVICE_URL=http://core_flask_service:5000
DJANGO_SERVICE_URL=http://backend_api:8000
REDIS_URL=redis://redis:6379/0
DJANGO_JWT_ISSUER=https://identity.yourdomain.com/servicefabric
DJANGO_JWT_AUDIENCE=servicefabric-production
DJANGO_JWT_TOKEN_TYPE=access
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_PATH=/

# --- Flask Legacy Containment (production fails closed) ---
FLASK_ENVIRONMENT=production
ENABLE_DYNAMIC_SERVICE_IMPORTS=false
ENABLE_GENERATED_SERVICE_IMPORTS=false
ENABLE_LEGACY_FAAS_EXECUTION=false
ENABLE_INTERNAL_RELOAD=false
ENABLE_DEBUG_ROUTES=false
LEGACY_CATALOG_ALLOWLIST=
MAX_UPLOAD_BYTES=10485760
UPLOAD_ALLOWED_EXTENSIONS=csv,json,jpeg,jpg,pdf,png,txt

# --- FastAPI Security (required in production; replace all placeholders) ---
FABRIC_ENVIRONMENT=production
JWT_SECRET_KEY=replace_with_a_unique_32_character_minimum_secret
JWT_ALGORITHM=HS256
JWT_ISSUER=https://identity.yourdomain.com/servicefabric
JWT_AUDIENCE=servicefabric-fastapi
JWT_TOKEN_TYPE=fabric_internal
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOW_CREDENTIALS=true
MAX_REQUEST_BODY_BYTES=1048576
MAX_VECTOR_DOCUMENTS=100
MAX_VECTOR_DOCUMENT_CHARS=20000
MAX_VECTOR_METADATA_BYTES=8192
MAX_VECTOR_TOP_K=25

# --- AI API Keys ---
GEMINI_API_KEY=
OPENAI_API_KEY=
VITE_GEMINI_API_KEY=
MISTRAL_API_KEY=
