# ServiceFabric - Professional Git Configuration

# --- Secrets & Local Environment (CRITICAL: DO NOT REMOVE) ---
.env
.env.prod
.env.dev
credential-store.dev.json
credential-store*.json
*.sqlite3
ssl/*.key
ssl/*.pem
cloudflared-creds/
*.p12
*.crt

# --- OS / IDE Metadata ---
.DS_Store
.DS_Store?
.idea/
.vscode/
*.swp
*.swo

# --- Build Artifacts & Dependencies ---
# We ignore these because they are platform-specific and re-installed via Docker/NPM
node_modules/
dist/
build/
*.egg-info/
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# --- Local Data & Volumes ---
# We keep the directories (via .gitkeep) but ignore the data inside
7_user_media/*
!7_user_media/.gitkeep

8_backups/*
!8_backups/.gitkeep

postgres_data/

# --- Project-Specific Ignores ---
# Ignore generated service content but KEEP the catalog structure and shared utils
6_service_catalog/*
!6_service_catalog/.gitkeep
!6_service_catalog/_shared/
!6_service_catalog/README.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Docker
.dockerignore
.agent/
.agent-runs/
.agent-runtime.env
.agent-worktrees.env
.sf-agent-runtime/
.venv/
codex/runs/
