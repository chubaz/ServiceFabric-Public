{
  "$defs": {
    "ApplicationArtifactManifestSpec": {
      "additionalProperties": false,
      "properties": {
        "application_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Application Id",
          "type": "string"
        },
        "application_revision": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Application Revision",
          "type": "string"
        },
        "artifact_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Artifact Digest",
          "type": "string"
        },
        "artifact_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Artifact Id",
          "type": "string"
        },
        "build_spec_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Build Spec Digest",
          "type": "string"
        },
        "builder_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Builder Id",
          "type": "string"
        },
        "builder_revision": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Builder Revision",
          "type": "string"
        },
        "created_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Created At"
        },
        "entry_document": {
          "title": "Entry Document",
          "type": "string"
        },
        "files": {
          "items": {
            "$ref": "#/$defs/ArtifactFileManifest"
          },
          "maxItems": 4096,
          "minItems": 1,
          "title": "Files",
          "type": "array"
        },
        "provenance": {
          "$ref": "#/$defs/ArtifactProvenance"
        },
        "reproducibility": {
          "enum": [
            "reproducible",
            "conditionally_reproducible",
            "not_reproducible"
          ],
          "title": "Reproducibility",
          "type": "string"
        },
        "source_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Source Digest",
          "type": "string"
        },
        "total_size_bytes": {
          "minimum": 0,
          "title": "Total Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "artifact_id",
        "artifact_digest",
        "application_id",
        "application_revision",
        "builder_id",
        "builder_revision",
        "source_digest",
        "build_spec_digest",
        "files",
        "entry_document",
        "total_size_bytes",
        "reproducibility",
        "provenance"
      ],
      "title": "ApplicationArtifactManifestSpec",
      "type": "object"
    },
    "ArtifactFileManifest": {
      "additionalProperties": false,
      "properties": {
        "content_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Content Digest",
          "type": "string"
        },
        "media_type": {
          "maxLength": 128,
          "minLength": 3,
          "title": "Media Type",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "content_digest",
        "media_type",
        "size_bytes"
      ],
      "title": "ArtifactFileManifest",
      "type": "object"
    },
    "ArtifactProvenance": {
      "additionalProperties": false,
      "properties": {
        "build_spec_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Build Spec Digest",
          "type": "string"
        },
        "builder_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Builder Id",
          "type": "string"
        },
        "builder_revision": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Builder Revision",
          "type": "string"
        },
        "source_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Source Digest",
          "type": "string"
        },
        "source_manifest_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Source Manifest Ref",
          "type": "string"
        }
      },
      "required": [
        "source_manifest_ref",
        "source_digest",
        "build_spec_digest",
        "builder_id",
        "builder_revision"
      ],
      "title": "ArtifactProvenance",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/application-artifact-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "ApplicationArtifactManifest",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ApplicationArtifactManifestSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric ApplicationArtifactManifest v1alpha1",
  "type": "object"
}
