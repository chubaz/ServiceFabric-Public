{
  "$defs": {
    "EvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "claims": {
          "items": {
            "type": "string"
          },
          "maxItems": 32,
          "title": "Claims",
          "type": "array"
        },
        "collected_at": {
          "format": "date-time",
          "title": "Collected At",
          "type": "string"
        },
        "content_digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Digest"
        },
        "evidence_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Evidence Id",
          "type": "string"
        },
        "evidence_type": {
          "enum": [
            "document",
            "web_resource",
            "database_record",
            "provider_response",
            "calculation",
            "log_reference",
            "human_confirmation",
            "artifact"
          ],
          "title": "Evidence Type",
          "type": "string"
        },
        "locator": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "provenance_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 32,
          "title": "Provenance Refs",
          "type": "array"
        },
        "source_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Source Ref",
          "type": "string"
        },
        "summary": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "trust_classification": {
          "enum": [
            "untrusted",
            "external",
            "verified",
            "platform"
          ],
          "title": "Trust Classification",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "evidence_type",
        "source_ref",
        "locator",
        "collected_at",
        "trust_classification",
        "summary"
      ],
      "title": "EvidenceRecord",
      "type": "object"
    },
    "ToolError": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "authentication",
            "authorization",
            "delegation",
            "approval",
            "validation",
            "policy",
            "budget",
            "execution",
            "dependency",
            "output",
            "effect",
            "quality",
            "mcp",
            "runtime"
          ],
          "title": "Category",
          "type": "string"
        },
        "cause_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cause Ref"
        },
        "code": {
          "maxLength": 96,
          "minLength": 8,
          "title": "Code",
          "type": "string"
        },
        "correlation_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Correlation Ref"
        },
        "dependency_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Ref"
        },
        "details": {
          "additionalProperties": true,
          "maxProperties": 32,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retry_after": {
          "anyOf": [
            {
              "format": "duration",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry After"
        },
        "retry_classification": {
          "anyOf": [
            {
              "enum": [
                "transient",
                "throttled",
                "dependency_recovery",
                "manual_review"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Classification"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message"
      ],
      "title": "ToolError",
      "type": "object"
    },
    "ToolWarning": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "coverage",
            "evidence",
            "output",
            "dependency",
            "quality"
          ],
          "title": "Category",
          "type": "string"
        },
        "code": {
          "pattern": "^SF-WARN-[A-Z0-9_]+$",
          "title": "Code",
          "type": "string"
        },
        "details": {
          "additionalProperties": true,
          "maxProperties": 16,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "category"
      ],
      "title": "ToolWarning",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/application-build-result.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "application_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "Application Id",
      "type": "string"
    },
    "artifact_digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Artifact Digest"
    },
    "artifact_manifest_ref": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Artifact Manifest Ref"
    },
    "artifact_ref": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Artifact Ref"
    },
    "build_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "Build Id",
      "type": "string"
    },
    "errors": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ToolError"
      },
      "title": "Errors",
      "type": "array"
    },
    "evidence": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EvidenceRecord"
      },
      "title": "Evidence",
      "type": "array"
    },
    "kind": {
      "const": "ApplicationBuildResult",
      "title": "Kind",
      "type": "string"
    },
    "metrics": {
      "additionalProperties": {
        "type": "integer"
      },
      "maxProperties": 32,
      "title": "Metrics",
      "type": "object"
    },
    "revision": {
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "title": "Revision",
      "type": "string"
    },
    "status": {
      "enum": [
        "success",
        "error"
      ],
      "title": "Status",
      "type": "string"
    },
    "warnings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ToolWarning"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "status",
    "application_id",
    "revision",
    "build_id"
  ],
  "title": "ServiceFabric ApplicationBuildResult v1alpha1",
  "type": "object"
}
