    "caller_context": {
      "subject_ref": "capsule-client",
      "principal_type": "service",
      "tenant_ref": "tenant.platform",
      "issuer": "servicefabric",
      "audiences": ["servicefabric"],
      "scopes": ["capsules.host"],
      "authentication_strength": "workload"
    },
    "host_policy_ref": "loopback-static",
