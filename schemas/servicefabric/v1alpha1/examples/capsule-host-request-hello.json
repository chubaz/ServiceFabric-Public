{
  "apiVersion": "servicefabric.ai/v1alpha1",
  "kind": "CapsuleHostRequest",
  "metadata": {
    "id": "request.hello-capsule",
    "name": "Hello Capsule Host Request",
    "description": "Request to open a bounded loopback session.",
    "labels": {},
    "annotations": {},
    "owner_ref": {
      "kind": "team",
      "id": "platform"
    }
  },
  "spec": {
    "request_id": "request.hello-capsule",
    "capsule_id": "examples.hello-capsule",
