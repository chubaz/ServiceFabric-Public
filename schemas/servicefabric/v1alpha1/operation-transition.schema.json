{
  "$defs": {
    "OperationTransitionSpec": {
      "additionalProperties": false,
      "properties": {
        "actor_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Actor Ref",
          "type": "string"
        },
        "approval_binding_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Approval Binding Ref"
        },
        "attempt_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Attempt Ref"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolError"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Evidence Refs",
          "type": "array"
        },
        "expected_version": {
          "minimum": 1,
          "title": "Expected Version",
          "type": "integer"
        },
        "from_state": {
          "enum": [
            "accepted",
            "queued",
            "running",
            "waiting_for_approval",
            "waiting_for_dependency",
            "waiting_for_human",
            "succeeded",
            "partially_succeeded",
            "failed",
            "cancelled",
            "timed_out"
          ],
          "title": "From State",
          "type": "string"
        },
        "operation_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Operation Ref",
          "type": "string"
        },
        "reason_code": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Reason Code",
          "type": "string"
        },
        "result_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result Ref"
        },
        "resulting_version": {
          "minimum": 2,
          "title": "Resulting Version",
          "type": "integer"
        },
        "safe_reason": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Safe Reason",
          "type": "string"
        },
        "to_state": {
          "enum": [
            "accepted",
            "queued",
            "running",
            "waiting_for_approval",
            "waiting_for_dependency",
            "waiting_for_human",
            "succeeded",
            "partially_succeeded",
            "failed",
            "cancelled",
            "timed_out"
          ],
          "title": "To State",
          "type": "string"
        },
        "transition_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Transition Id",
          "type": "string"
        },
        "transitioned_at": {
          "format": "date-time",
          "title": "Transitioned At",
          "type": "string"
        }
      },
      "required": [
        "transition_id",
        "operation_ref",
        "from_state",
        "to_state",
        "expected_version",
        "resulting_version",
        "reason_code",
        "safe_reason",
        "transitioned_at",
        "actor_ref"
      ],
      "title": "OperationTransitionSpec",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    },
    "ToolError": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "authentication",
            "authorization",
            "delegation",
            "approval",
            "validation",
            "policy",
            "budget",
            "execution",
            "dependency",
            "output",
            "effect",
            "quality",
            "mcp",
            "runtime"
          ],
          "title": "Category",
          "type": "string"
        },
        "cause_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cause Ref"
        },
        "code": {
          "maxLength": 96,
          "minLength": 8,
          "title": "Code",
          "type": "string"
        },
        "correlation_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Correlation Ref"
        },
        "dependency_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Ref"
        },
        "details": {
          "additionalProperties": true,
          "maxProperties": 32,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retry_after": {
          "anyOf": [
            {
              "format": "duration",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry After"
        },
        "retry_classification": {
          "anyOf": [
            {
              "enum": [
                "transient",
                "throttled",
                "dependency_recovery",
                "manual_review"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Classification"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message"
      ],
      "title": "ToolError",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/operation-transition.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "OperationTransition",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/OperationTransitionSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric OperationTransition v1alpha1",
  "type": "object"
}
