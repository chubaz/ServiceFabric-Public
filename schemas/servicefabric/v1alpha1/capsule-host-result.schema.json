{
  "$defs": {
    "CapsuleHostResultSpec": {
      "additionalProperties": false,
      "properties": {
        "effect_receipts": {
          "items": {
            "$ref": "#/$defs/EffectReceipt"
          },
          "maxItems": 64,
          "title": "Effect Receipts",
          "type": "array"
        },
        "errors": {
          "items": {
            "$ref": "#/$defs/ToolError"
          },
          "maxItems": 64,
          "title": "Errors",
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceRecord"
          },
          "maxItems": 64,
          "title": "Evidence",
          "type": "array"
        },
        "metrics": {
          "additionalProperties": {
            "type": "integer"
          },
          "maxProperties": 32,
          "title": "Metrics",
          "type": "object"
        },
        "session": {
          "anyOf": [
            {
              "$ref": "#/$defs/CapsuleHostSession"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "status": {
          "enum": [
            "success",
            "partial",
            "error"
          ],
          "title": "Status",
          "type": "string"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/ToolWarning"
          },
          "maxItems": 64,
          "title": "Warnings",
          "type": "array"
        }
      },
      "required": [
        "status"
      ],
      "title": "CapsuleHostResultSpec",
      "type": "object"
    },
    "CapsuleHostSession": {
      "additionalProperties": false,
      "properties": {
        "apiVersion": {
          "const": "servicefabric.ai/v1alpha1",
          "title": "Apiversion",
          "type": "string"
        },
        "kind": {
          "const": "CapsuleHostSession",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/ResourceMetadata"
        },
        "spec": {
          "$ref": "#/$defs/CapsuleHostSessionSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "title": "CapsuleHostSession",
      "type": "object"
    },
    "CapsuleHostSessionSpec": {
      "additionalProperties": false,
      "properties": {
        "artifact_digests": {
          "items": {
            "pattern": "^sha256:[a-f0-9]{64}$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Artifact Digests",
          "type": "array"
        },
        "base_url": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Base Url",
          "type": "string"
        },
        "capsule_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Capsule Digest",
          "type": "string"
        },
        "capsule_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Capsule Id",
          "type": "string"
        },
        "capsule_revision": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Capsule Revision",
          "type": "string"
        },
        "expires_at": {
          "format": "date-time",
          "title": "Expires At",
          "type": "string"
        },
        "host": {
          "enum": [
            "127.0.0.1",
            "::1"
          ],
          "title": "Host",
          "type": "string"
        },
        "opened_at": {
          "format": "date-time",
          "title": "Opened At",
          "type": "string"
        },
        "port": {
          "maximum": 65535,
          "minimum": 0,
          "title": "Port",
          "type": "integer"
        },
        "request_budget": {
          "$ref": "#/$defs/ExecutionBudget"
        },
        "requests_served": {
          "minimum": 0,
          "title": "Requests Served",
          "type": "integer"
        },
        "session_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Session Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "opening",
            "open",
            "closing",
            "closed",
            "expired"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "session_id",
        "capsule_id",
        "capsule_revision",
        "capsule_digest",
        "host",
        "port",
        "base_url",
        "status",
        "opened_at",
        "expires_at",
        "request_budget",
        "requests_served"
      ],
      "title": "CapsuleHostSessionSpec",
      "type": "object"
    },
    "EffectReceipt": {
      "additionalProperties": false,
      "properties": {
        "apiVersion": {
          "const": "servicefabric.ai/v1alpha1",
          "title": "Apiversion",
          "type": "string"
        },
        "kind": {
          "const": "EffectReceipt",
          "title": "Kind",
          "type": "string"
        },
        "metadata": {
          "$ref": "#/$defs/ResourceMetadata"
        },
        "spec": {
          "$ref": "#/$defs/EffectReceiptSpec"
        }
      },
      "required": [
        "apiVersion",
        "kind",
        "metadata",
        "spec"
      ],
      "title": "EffectReceipt",
      "type": "object"
    },
    "EffectReceiptSpec": {
      "additionalProperties": false,
      "properties": {
        "declared_effect_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Declared Effect Ref",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Evidence Refs",
          "type": "array"
        },
        "idempotency_digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Idempotency Digest"
        },
        "invocation_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Invocation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "observed_effects": {
          "items": {
            "$ref": "#/$defs/ObservedEffect"
          },
          "maxItems": 64,
          "title": "Observed Effects",
          "type": "array"
        },
        "receipt_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Receipt Id",
          "type": "string"
        },
        "revision_ref": {
          "pattern": "^[a-z0-9][a-z0-9._:-]+$",
          "title": "Revision Ref",
          "type": "string"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        },
        "verification_method": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Verification Method"
        },
        "verification_status": {
          "enum": [
            "unverified",
            "verified",
            "partially_verified",
            "verification_failed",
            "reconciled"
          ],
          "title": "Verification Status",
          "type": "string"
        },
        "verified_no_op": {
          "default": false,
          "title": "Verified No Op",
          "type": "boolean"
        }
      },
      "required": [
        "receipt_id",
        "invocation_id",
        "tool_id",
        "revision_ref",
        "declared_effect_ref",
        "verification_status",
        "issued_at"
      ],
      "title": "EffectReceiptSpec",
      "type": "object"
    },
    "EvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "claims": {
          "items": {
            "type": "string"
          },
          "maxItems": 32,
          "title": "Claims",
          "type": "array"
        },
        "collected_at": {
          "format": "date-time",
          "title": "Collected At",
          "type": "string"
        },
        "content_digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Digest"
        },
        "evidence_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Evidence Id",
          "type": "string"
        },
        "evidence_type": {
          "enum": [
            "document",
            "web_resource",
            "database_record",
            "provider_response",
            "calculation",
            "log_reference",
            "human_confirmation",
            "artifact"
          ],
          "title": "Evidence Type",
          "type": "string"
        },
        "locator": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Locator",
          "type": "string"
        },
        "provenance_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 32,
          "title": "Provenance Refs",
          "type": "array"
        },
        "source_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Source Ref",
          "type": "string"
        },
        "summary": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "trust_classification": {
          "enum": [
            "untrusted",
            "external",
            "verified",
            "platform"
          ],
          "title": "Trust Classification",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "evidence_type",
        "source_ref",
        "locator",
        "collected_at",
        "trust_classification",
        "summary"
      ],
      "title": "EvidenceRecord",
      "type": "object"
    },
    "ExecutionBudget": {
      "additionalProperties": false,
      "properties": {
        "deadline": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Deadline"
        },
        "maximum_bytes_in": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Bytes In"
        },
        "maximum_bytes_out": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Bytes Out"
        },
        "maximum_effect_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Effect Count"
        },
        "maximum_evidence_records": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Evidence Records"
        },
        "maximum_model_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Model Tokens"
        },
        "maximum_monetary_cost": {
          "anyOf": [
            {
              "$ref": "#/$defs/MonetaryBudget"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "maximum_nested_tool_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Nested Tool Calls"
        },
        "maximum_provider_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Provider Calls"
        },
        "maximum_wall_clock_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Wall Clock Ms"
        }
      },
      "title": "ExecutionBudget",
      "type": "object"
    },
    "MonetaryBudget": {
      "additionalProperties": false,
      "properties": {
        "amount": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*(?:\\d{0,12}|(?=[\\d.]{1,19}0*$)\\d{0,12}\\.\\d{0,6}0*$)",
              "type": "string"
            }
          ],
          "title": "Amount"
        },
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "amount",
        "currency"
      ],
      "title": "MonetaryBudget",
      "type": "object"
    },
    "ObservedEffect": {
      "additionalProperties": false,
      "properties": {
        "after_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "After Ref"
        },
        "before_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Before Ref"
        },
        "declared_effect_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Declared Effect Ref",
          "type": "string"
        },
        "effect_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Effect Id",
          "type": "string"
        },
        "effect_type": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Effect Type",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "provider_operation_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Operation Ref"
        },
        "reversibility": {
          "enum": [
            "reversible",
            "irreversible",
            "unknown"
          ],
          "title": "Reversibility",
          "type": "string"
        },
        "state": {
          "enum": [
            "attempted",
            "committed",
            "verified",
            "reconciled",
            "reversed",
            "failed",
            "unknown"
          ],
          "title": "State",
          "type": "string"
        },
        "target_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Target Ref",
          "type": "string"
        }
      },
      "required": [
        "effect_id",
        "declared_effect_ref",
        "effect_type",
        "target_ref",
        "state",
        "observed_at",
        "reversibility"
      ],
      "title": "ObservedEffect",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    },
    "ToolError": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "authentication",
            "authorization",
            "delegation",
            "approval",
            "validation",
            "policy",
            "budget",
            "execution",
            "dependency",
            "output",
            "effect",
            "quality",
            "mcp",
            "runtime"
          ],
          "title": "Category",
          "type": "string"
        },
        "cause_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cause Ref"
        },
        "code": {
          "maxLength": 96,
          "minLength": 8,
          "title": "Code",
          "type": "string"
        },
        "correlation_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Correlation Ref"
        },
        "dependency_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Ref"
        },
        "details": {
          "additionalProperties": true,
          "maxProperties": 32,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retry_after": {
          "anyOf": [
            {
              "format": "duration",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry After"
        },
        "retry_classification": {
          "anyOf": [
            {
              "enum": [
                "transient",
                "throttled",
                "dependency_recovery",
                "manual_review"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Classification"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message"
      ],
      "title": "ToolError",
      "type": "object"
    },
    "ToolWarning": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "coverage",
            "evidence",
            "output",
            "dependency",
            "quality"
          ],
          "title": "Category",
          "type": "string"
        },
        "code": {
          "pattern": "^SF-WARN-[A-Z0-9_]+$",
