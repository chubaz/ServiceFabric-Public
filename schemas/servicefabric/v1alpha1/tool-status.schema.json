{
  "$defs": {
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    },
    "ToolCondition": {
      "additionalProperties": false,
      "properties": {
        "message": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "reason": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Reason",
          "type": "string"
        },
        "status": {
          "enum": [
            "true",
            "false",
            "unknown"
          ],
          "title": "Status",
          "type": "string"
        },
        "type": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status",
        "reason",
        "message",
        "observed_at"
      ],
      "title": "ToolCondition",
      "type": "object"
    },
    "ToolRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "content_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Content Digest",
          "type": "string"
        },
        "revision": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Revision",
          "type": "string"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        }
      },
      "required": [
        "tool_id",
        "revision",
        "content_digest"
      ],
      "title": "ToolRevisionReference",
      "type": "object"
    },
    "ToolStatusSpec": {
      "additionalProperties": false,
      "properties": {
        "availability": {
          "enum": [
            "unknown",
            "available",
            "degraded",
            "unavailable",
            "disabled"
          ],
          "title": "Availability",
          "type": "string"
        },
        "conditions": {
          "items": {
            "$ref": "#/$defs/ToolCondition"
          },
          "maxItems": 64,
          "title": "Conditions",
          "type": "array"
        },
        "deployment_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Deployment Ref",
          "type": "string"
        },
        "last_transition": {
          "format": "date-time",
          "title": "Last Transition",
          "type": "string"
        },
        "maintenance_state": {
          "enum": [
            "unknown",
            "normal",
            "maintenance",
            "quarantined"
          ],
          "title": "Maintenance State",
          "type": "string"
        },
        "observed_evidence_refs": {
          "items": {
            "type": "string"
          },
          "maxItems": 64,
          "title": "Observed Evidence Refs",
          "type": "array"
        },
        "observed_version": {
          "minimum": 1,
          "title": "Observed Version",
          "type": "integer"
        },
        "readiness": {
          "enum": [
            "unknown",
            "ready",
            "not_ready"
          ],
          "title": "Readiness",
          "type": "string"
        },
        "revision_ref": {
          "$ref": "#/$defs/ToolRevisionReference"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        }
      },
      "required": [
        "tool_id",
        "deployment_ref",
        "revision_ref",
        "availability",
        "maintenance_state",
        "readiness",
        "last_transition",
        "observed_version"
      ],
      "title": "ToolStatusSpec",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/tool-status.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "ToolStatus",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ToolStatusSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric ToolStatus v1alpha1",
  "type": "object"
}
