{
  "$defs": {
    "ExecutionAttemptSpec": {
      "additionalProperties": false,
      "properties": {
        "attempt_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Attempt Id",
          "type": "string"
        },
        "attempt_number": {
          "maximum": 32,
          "minimum": 1,
          "title": "Attempt Number",
          "type": "integer"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        },
        "effect_uncertainty": {
          "default": "none",
          "enum": [
            "none",
            "possible",
            "confirmed"
          ],
          "title": "Effect Uncertainty",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolError"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Evidence Refs",
          "type": "array"
        },
        "invocation_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Invocation Ref",
          "type": "string"
        },
        "next_eligible_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Next Eligible At"
        },
        "operation_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Operation Ref",
          "type": "string"
        },
        "result_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result Ref"
        },
        "retry_eligibility": {
          "enum": [
            "not_evaluated",
            "eligible",
            "ineligible",
            "blocked_pending_reconciliation"
          ],
          "title": "Retry Eligibility",
          "type": "string"
        },
        "revision_ref": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Revision Ref",
          "type": "string"
        },
        "started_at": {
          "format": "date-time",
          "title": "Started At",
          "type": "string"
        },
        "state": {
          "enum": [
            "started",
            "succeeded",
            "failed",
            "cancelled",
            "timed_out",
            "uncertain"
          ],
          "title": "State",
          "type": "string"
        }
      },
      "required": [
        "attempt_id",
        "operation_ref",
        "invocation_ref",
        "revision_ref",
        "attempt_number",
        "state",
        "started_at",
        "retry_eligibility"
      ],
      "title": "ExecutionAttemptSpec",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    },
    "ToolError": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "authentication",
            "authorization",
            "delegation",
            "approval",
            "validation",
            "policy",
            "budget",
            "execution",
            "dependency",
            "output",
            "effect",
            "quality",
            "mcp",
            "runtime"
          ],
          "title": "Category",
          "type": "string"
        },
        "cause_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cause Ref"
        },
        "code": {
          "maxLength": 96,
          "minLength": 8,
          "title": "Code",
          "type": "string"
        },
        "correlation_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Correlation Ref"
        },
        "dependency_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Ref"
        },
        "details": {
          "additionalProperties": true,
          "maxProperties": 32,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retry_after": {
          "anyOf": [
            {
              "format": "duration",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry After"
        },
        "retry_classification": {
          "anyOf": [
            {
              "enum": [
                "transient",
                "throttled",
                "dependency_recovery",
                "manual_review"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Classification"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message"
      ],
      "title": "ToolError",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/execution-attempt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "ExecutionAttempt",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ExecutionAttemptSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric ExecutionAttempt v1alpha1",
  "type": "object"
}
