{
  "$defs": {
    "ApprovalRequestSpec": {
      "additionalProperties": false,
      "properties": {
        "approval_request_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Approval Request Id",
          "type": "string"
        },
        "approval_scope": {
          "$ref": "#/$defs/ApprovalScope"
        },
        "argument_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Argument Digest",
          "type": "string"
        },
        "caller_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Caller Ref",
          "type": "string"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "effect_class": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Effect Class",
          "type": "string"
        },
        "expires_at": {
          "format": "date-time",
          "title": "Expires At",
          "type": "string"
        },
        "intent_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Intent Digest",
          "type": "string"
        },
        "operation_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Operation Ref",
          "type": "string"
        },
        "policy_decision_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Policy Decision Digest",
          "type": "string"
        },
        "policy_decision_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Policy Decision Ref",
          "type": "string"
        },
        "reason": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Reason",
          "type": "string"
        },
        "request_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Request Ref",
          "type": "string"
        },
        "requested_authority": {
          "$ref": "#/$defs/AuthorityGrant"
        },
        "revision_ref": {
          "maxLength": 160,
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9._:-]+$",
          "title": "Revision Ref",
          "type": "string"
        },
        "risk": {
          "enum": [
            "low",
            "moderate",
            "high",
            "critical"
          ],
          "title": "Risk",
          "type": "string"
        },
        "tenant_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tenant Ref"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        }
      },
      "required": [
        "approval_request_id",
        "policy_decision_ref",
        "policy_decision_digest",
        "request_ref",
        "operation_ref",
        "caller_ref",
        "tool_id",
        "revision_ref",
        "intent_digest",
        "argument_digest",
        "effect_class",
        "requested_authority",
        "approval_scope",
        "risk",
        "reason",
        "created_at",
        "expires_at"
      ],
      "title": "ApprovalRequestSpec",
      "type": "object"
    },
    "ApprovalScope": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "$ref": "#/$defs/AuthorityGrant"
        },
        "effect_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 32,
          "minItems": 1,
          "title": "Effect Refs",
          "type": "array"
        },
        "single_use": {
          "default": true,
          "title": "Single Use",
          "type": "boolean"
        }
      },
      "required": [
        "effect_refs",
        "authority"
      ],
      "title": "ApprovalScope",
      "type": "object"
    },
    "AuthorityGrant": {
      "additionalProperties": false,
      "properties": {
        "resource_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Resource Refs",
          "type": "array"
        },
        "scopes": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Scopes",
          "type": "array"
        },
        "tenant_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tenant Ref"
        }
      },
      "title": "AuthorityGrant",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/approval-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "ApprovalRequest",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ApprovalRequestSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric ApprovalRequest v1alpha1",
  "type": "object"
}
