{
  "$id": "https://schemas.servicefabric.ai/v1alpha1/evidence-record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "claims": {
      "items": {
        "type": "string"
      },
      "maxItems": 32,
      "title": "Claims",
      "type": "array"
    },
    "collected_at": {
      "format": "date-time",
      "title": "Collected At",
      "type": "string"
    },
    "content_digest": {
      "anyOf": [
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content Digest"
    },
    "evidence_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "Evidence Id",
      "type": "string"
    },
    "evidence_type": {
      "enum": [
        "document",
        "web_resource",
        "database_record",
        "provider_response",
        "calculation",
        "log_reference",
        "human_confirmation",
        "artifact"
      ],
      "title": "Evidence Type",
      "type": "string"
    },
    "locator": {
      "maxLength": 512,
      "minLength": 1,
      "title": "Locator",
      "type": "string"
    },
    "provenance_refs": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
        "type": "string"
      },
      "maxItems": 32,
      "title": "Provenance Refs",
      "type": "array"
    },
    "source_ref": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
      "title": "Source Ref",
      "type": "string"
    },
    "summary": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Summary",
      "type": "string"
    },
    "trust_classification": {
      "enum": [
        "untrusted",
        "external",
        "verified",
        "platform"
      ],
      "title": "Trust Classification",
      "type": "string"
    }
  },
  "required": [
    "evidence_id",
    "evidence_type",
    "source_ref",
    "locator",
    "collected_at",
    "trust_classification",
    "summary"
  ],
  "title": "ServiceFabric EvidenceRecord v1alpha1",
  "type": "object"
}
