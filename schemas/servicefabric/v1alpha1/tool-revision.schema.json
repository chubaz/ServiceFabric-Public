          "minLength": 3,
          "pattern": "^build://[a-z][a-z0-9._:/-]+$",
          "title": "Build Ref",
          "type": "string"
        },
        "source_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Source Digest",
          "type": "string"
        },
        "source_ref": {
          "maxLength": 256,
          "minLength": 3,
          "pattern": "^source://[a-z][a-z0-9._:/-]+$",
          "title": "Source Ref",
          "type": "string"
        }
      },
      "required": [
        "source_ref",
        "source_digest",
        "build_ref"
      ],
      "title": "RevisionProvenance",
      "type": "object"
    },
    "RevisionResourceRequirements": {
      "additionalProperties": false,
      "properties": {
        "cpu_millicores": {
          "anyOf": [
            {
              "maximum": 64000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cpu Millicores"
        },
        "memory_mebibytes": {
          "anyOf": [
            {
              "maximum": 1048576,
              "minimum": 16,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Memory Mebibytes"
        },
        "network_policy_ref": {
          "maxLength": 256,
          "minLength": 3,
          "pattern": "^policy://[a-z][a-z0-9._:/-]+$",
          "title": "Network Policy Ref",
          "type": "string"
        },
        "storage_requirement_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 32,
          "title": "Storage Requirement Refs",
          "type": "array"
        }
      },
      "required": [
        "network_policy_ref"
      ],
      "title": "RevisionResourceRequirements",
      "type": "object"
    },
    "SchemaReference": {
      "additionalProperties": false,
      "properties": {
        "schema_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Schema Digest",
          "type": "string"
        },
        "schema_ref": {
          "maxLength": 256,
          "minLength": 3,
          "pattern": "^schema://[a-z][a-z0-9._:/-]+$",
          "title": "Schema Ref",
          "type": "string"
        }
      },
      "required": [
        "schema_ref",
        "schema_digest"
      ],
      "title": "SchemaReference",
      "type": "object"
    },
    "ServicePackageRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "entrypoint_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Entrypoint Id",
          "type": "string"
        },
        "package_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Package Id",
          "type": "string"
        },
        "package_version": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Package Version",
          "type": "string"
        }
      },
      "required": [
        "package_id",
        "package_version",
        "entrypoint_id"
      ],
      "title": "ServicePackageRevisionReference",
      "type": "object"
    },
    "TimeoutDeclaration": {
      "additionalProperties": false,
      "properties": {
        "maximum_timeout_ms": {
          "maximum": 86400000,
          "minimum": 1,
          "title": "Maximum Timeout Ms",
          "type": "integer"
        },
        "timeout_class": {
          "enum": [
            "short",
            "bounded_long",
            "durable"
          ],
          "title": "Timeout Class",
          "type": "string"
        }
      },
      "required": [
        "timeout_class",
        "maximum_timeout_ms"
      ],
      "title": "TimeoutDeclaration",
      "type": "object"
    },
    "ToolDefinitionReference": {
      "additionalProperties": false,
      "properties": {
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        }
      },
      "required": [
        "tool_id"
      ],
      "title": "ToolDefinitionReference",
      "type": "object"
    },
    "ToolDependency": {
      "additionalProperties": false,
      "properties": {
        "dependency_kind": {
          "const": "tool",
          "title": "Dependency Kind",
          "type": "string"
        },
        "revision_constraint": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Revision Constraint",
          "type": "string"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        }
      },
      "required": [
        "dependency_kind",
        "tool_id",
        "revision_constraint"
      ],
      "title": "ToolDependency",
      "type": "object"
    },
    "ToolRevisionSpec": {
      "additionalProperties": false,
      "properties": {
        "cancellation": {
          "$ref": "#/$defs/CancellationDeclaration"
        },
        "compatibility": {
          "$ref": "#/$defs/CompatibilityDeclaration"
        },
        "content_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Content Digest",
          "type": "string"
        },
        "definition_ref": {
          "$ref": "#/$defs/ToolDefinitionReference"
        },
        "dependency_contract": {
          "$ref": "#/$defs/DependencyContract"
        },
        "effect_contract": {
          "$ref": "#/$defs/EffectContract"
        },
        "error_contract": {
          "$ref": "#/$defs/ErrorContractDeclaration"
        },
        "evidence_policy": {
          "$ref": "#/$defs/EvidencePolicy"
        },
        "execution_binding": {
          "discriminator": {
            "mapping": {
              "command_runner": "#/$defs/CommandRunnerBinding",
              "database_operation": "#/$defs/DatabaseOperationBinding",
              "external_http": "#/$defs/ExternalHttpBinding",
              "federated_mcp": "#/$defs/FederatedMcpBinding",
              "human_task": "#/$defs/HumanTaskBinding",
              "internal_graph": "#/$defs/InternalGraphBinding",
              "native_function": "#/$defs/NativeFunctionBinding",
              "native_service": "#/$defs/NativeServiceBinding"
            },
            "propertyName": "binding_kind"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/NativeFunctionBinding"
            },
            {
              "$ref": "#/$defs/NativeServiceBinding"
            },
            {
              "$ref": "#/$defs/InternalGraphBinding"
            },
            {
              "$ref": "#/$defs/ExternalHttpBinding"
            },
            {
              "$ref": "#/$defs/DatabaseOperationBinding"
            },
            {
              "$ref": "#/$defs/CommandRunnerBinding"
            },
            {
              "$ref": "#/$defs/FederatedMcpBinding"
            },
            {
              "$ref": "#/$defs/HumanTaskBinding"
            }
          ],
          "title": "Execution Binding"
        },
        "idempotency": {
          "$ref": "#/$defs/IdempotencyDeclaration"
        },
        "input_schema": {
          "$ref": "#/$defs/SchemaReference"
        },
        "output_schema": {
          "$ref": "#/$defs/SchemaReference"
        },
        "package_ref": {
          "$ref": "#/$defs/ServicePackageRevisionReference"
        },
        "provenance": {
          "$ref": "#/$defs/RevisionProvenance"
        },
        "resource_requirements": {
          "$ref": "#/$defs/RevisionResourceRequirements"
        },
        "revision": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Revision",
          "type": "string"
        },
        "timeouts": {
          "$ref": "#/$defs/TimeoutDeclaration"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        }
      },
      "required": [
        "tool_id",
        "revision",
        "definition_ref",
        "package_ref",
        "execution_binding",
        "input_schema",
        "output_schema",
        "error_contract",
        "effect_contract",
        "dependency_contract",
        "resource_requirements",
        "timeouts",
        "idempotency",
        "cancellation",
        "evidence_policy",
        "compatibility",
        "provenance",
        "content_digest"
      ],
      "title": "ToolRevisionSpec",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/tool-revision.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "ToolRevision",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ToolRevisionSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric ToolRevision v1alpha1",
  "type": "object"
}
