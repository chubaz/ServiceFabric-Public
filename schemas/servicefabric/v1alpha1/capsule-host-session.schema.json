{
  "$defs": {
    "CapsuleHostSessionSpec": {
      "additionalProperties": false,
      "properties": {
        "artifact_digests": {
          "items": {
            "pattern": "^sha256:[a-f0-9]{64}$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Artifact Digests",
          "type": "array"
        },
        "base_url": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Base Url",
          "type": "string"
        },
        "capsule_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Capsule Digest",
          "type": "string"
        },
        "capsule_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Capsule Id",
          "type": "string"
        },
        "capsule_revision": {
          "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
          "title": "Capsule Revision",
          "type": "string"
        },
        "expires_at": {
          "format": "date-time",
          "title": "Expires At",
          "type": "string"
        },
        "host": {
          "enum": [
            "127.0.0.1",
            "::1"
          ],
          "title": "Host",
          "type": "string"
        },
        "opened_at": {
          "format": "date-time",
          "title": "Opened At",
          "type": "string"
        },
        "port": {
          "maximum": 65535,
          "minimum": 0,
          "title": "Port",
          "type": "integer"
        },
        "request_budget": {
          "$ref": "#/$defs/ExecutionBudget"
        },
        "requests_served": {
          "minimum": 0,
          "title": "Requests Served",
          "type": "integer"
        },
        "session_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Session Id",
          "type": "string"
        },
        "status": {
          "enum": [
            "opening",
            "open",
            "closing",
            "closed",
            "expired"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "session_id",
        "capsule_id",
        "capsule_revision",
        "capsule_digest",
        "host",
        "port",
        "base_url",
        "status",
        "opened_at",
        "expires_at",
        "request_budget",
        "requests_served"
      ],
      "title": "CapsuleHostSessionSpec",
      "type": "object"
    },
    "ExecutionBudget": {
      "additionalProperties": false,
      "properties": {
        "deadline": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Deadline"
        },
        "maximum_bytes_in": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Bytes In"
        },
        "maximum_bytes_out": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Bytes Out"
        },
        "maximum_effect_count": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Effect Count"
        },
        "maximum_evidence_records": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Evidence Records"
        },
        "maximum_model_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Model Tokens"
        },
        "maximum_monetary_cost": {
          "anyOf": [
            {
              "$ref": "#/$defs/MonetaryBudget"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "maximum_nested_tool_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Nested Tool Calls"
        },
        "maximum_provider_calls": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Provider Calls"
        },
        "maximum_wall_clock_ms": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Maximum Wall Clock Ms"
        }
      },
      "title": "ExecutionBudget",
      "type": "object"
    },
    "MonetaryBudget": {
      "additionalProperties": false,
      "properties": {
        "amount": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*(?:\\d{0,12}|(?=[\\d.]{1,19}0*$)\\d{0,12}\\.\\d{0,6}0*$)",
              "type": "string"
            }
          ],
          "title": "Amount"
        },
        "currency": {
          "pattern": "^[A-Z]{3}$",
          "title": "Currency",
          "type": "string"
        }
      },
      "required": [
        "amount",
        "currency"
      ],
      "title": "MonetaryBudget",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/capsule-host-session.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "CapsuleHostSession",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/CapsuleHostSessionSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric CapsuleHostSession v1alpha1",
  "type": "object"
}
