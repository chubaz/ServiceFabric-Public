{
  "$defs": {
    "CancellationState": {
      "additionalProperties": false,
      "properties": {
        "cancellable": {
          "title": "Cancellable",
          "type": "boolean"
        },
        "cancellation_reason": {
          "anyOf": [
            {
              "maxLength": 1000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cancellation Reason"
        },
        "cancellation_requested_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cancellation Requested At"
        },
        "cancellation_state": {
          "default": "not_requested",
          "enum": [
            "not_requested",
            "requested",
            "acknowledged",
            "completed",
            "rejected"
          ],
          "title": "Cancellation State",
          "type": "string"
        }
      },
      "required": [
        "cancellable"
      ],
      "title": "CancellationState",
      "type": "object"
    },
    "OperationCondition": {
      "additionalProperties": false,
      "properties": {
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "reason": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Reason",
          "type": "string"
        },
        "status": {
          "enum": [
            "true",
            "false",
            "unknown"
          ],
          "title": "Status",
          "type": "string"
        },
        "type": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "status",
        "reason",
        "message",
        "observed_at"
      ],
      "title": "OperationCondition",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    },
    "ServiceFabricOperationSpec": {
      "additionalProperties": false,
      "properties": {
        "cancellation": {
          "$ref": "#/$defs/CancellationState"
        },
        "completed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Completed At"
        },
        "conditions": {
          "items": {
            "$ref": "#/$defs/OperationCondition"
          },
          "maxItems": 64,
          "title": "Conditions",
          "type": "array"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/ToolError"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "invocation_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Invocation Ref",
          "type": "string"
        },
        "operation_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Operation Id",
          "type": "string"
        },
        "progress": {
          "anyOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Progress"
        },
        "request_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Request Ref",
          "type": "string"
        },
        "result_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Result Ref"
        },
        "revision_ref": {
          "title": "Revision Ref",
          "type": "string"
        },
        "state": {
          "enum": [
            "accepted",
            "queued",
            "running",
            "waiting_for_approval",
            "waiting_for_dependency",
            "waiting_for_human",
            "succeeded",
            "partially_succeeded",
            "failed",
            "cancelled",
            "timed_out"
          ],
          "title": "State",
          "type": "string"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "title": "Updated At",
          "type": "string"
        }
      },
      "required": [
        "operation_id",
        "request_ref",
        "invocation_ref",
        "tool_id",
        "revision_ref",
        "state",
        "created_at",
        "updated_at",
        "cancellation"
      ],
      "title": "ServiceFabricOperationSpec",
      "type": "object"
    },
    "ToolError": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "enum": [
            "authentication",
            "authorization",
            "delegation",
            "approval",
            "validation",
            "policy",
            "budget",
            "execution",
            "dependency",
            "output",
            "effect",
            "quality",
            "mcp",
            "runtime"
          ],
          "title": "Category",
          "type": "string"
        },
        "cause_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cause Ref"
        },
        "code": {
          "maxLength": 96,
          "minLength": 8,
          "title": "Code",
          "type": "string"
        },
        "correlation_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Correlation Ref"
        },
        "dependency_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dependency Ref"
        },
        "details": {
          "additionalProperties": true,
          "maxProperties": 32,
          "title": "Details",
          "type": "object"
        },
        "message": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "retry_after": {
          "anyOf": [
            {
              "format": "duration",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry After"
        },
        "retry_classification": {
          "anyOf": [
            {
              "enum": [
                "transient",
                "throttled",
                "dependency_recovery",
                "manual_review"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry Classification"
        },
        "retryable": {
          "default": false,
          "title": "Retryable",
          "type": "boolean"
        }
      },
      "required": [
        "code",
        "category",
        "message"
      ],
      "title": "ToolError",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/servicefabric-operation.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "ServiceFabricOperation",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ServiceFabricOperationSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric Operation v1alpha1",
  "type": "object"
}
