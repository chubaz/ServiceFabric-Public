{
  "$defs": {
    "EffectReceiptSpec": {
      "additionalProperties": false,
      "properties": {
        "declared_effect_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Declared Effect Ref",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Evidence Refs",
          "type": "array"
        },
        "idempotency_digest": {
          "anyOf": [
            {
              "pattern": "^sha256:[a-f0-9]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Idempotency Digest"
        },
        "invocation_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Invocation Id",
          "type": "string"
        },
        "issued_at": {
          "format": "date-time",
          "title": "Issued At",
          "type": "string"
        },
        "observed_effects": {
          "items": {
            "$ref": "#/$defs/ObservedEffect"
          },
          "maxItems": 64,
          "title": "Observed Effects",
          "type": "array"
        },
        "receipt_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Receipt Id",
          "type": "string"
        },
        "revision_ref": {
          "pattern": "^[a-z0-9][a-z0-9._:-]+$",
          "title": "Revision Ref",
          "type": "string"
        },
        "tool_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-z][a-z0-9_-]{0,62}\\.[a-z][a-z0-9_]{0,62}$",
          "title": "Tool Id",
          "type": "string"
        },
        "verification_method": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Verification Method"
        },
        "verification_status": {
          "enum": [
            "unverified",
            "verified",
            "partially_verified",
            "verification_failed",
            "reconciled"
          ],
          "title": "Verification Status",
          "type": "string"
        },
        "verified_no_op": {
          "default": false,
          "title": "Verified No Op",
          "type": "boolean"
        }
      },
      "required": [
        "receipt_id",
        "invocation_id",
        "tool_id",
        "revision_ref",
        "declared_effect_ref",
        "verification_status",
        "issued_at"
      ],
      "title": "EffectReceiptSpec",
      "type": "object"
    },
    "ObservedEffect": {
      "additionalProperties": false,
      "properties": {
        "after_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "After Ref"
        },
        "before_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Before Ref"
        },
        "declared_effect_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Declared Effect Ref",
          "type": "string"
        },
        "effect_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Effect Id",
          "type": "string"
        },
        "effect_type": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Effect Type",
          "type": "string"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        },
        "provider_operation_ref": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider Operation Ref"
        },
        "reversibility": {
          "enum": [
            "reversible",
            "irreversible",
            "unknown"
          ],
          "title": "Reversibility",
          "type": "string"
        },
        "state": {
          "enum": [
            "attempted",
            "committed",
            "verified",
            "reconciled",
            "reversed",
            "failed",
            "unknown"
          ],
          "title": "State",
          "type": "string"
        },
        "target_ref": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Target Ref",
          "type": "string"
        }
      },
      "required": [
        "effect_id",
        "declared_effect_ref",
        "effect_type",
        "target_ref",
        "state",
        "observed_at",
        "reversibility"
      ],
      "title": "ObservedEffect",
      "type": "object"
    },
    "OwnerReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "kind": {
          "maxLength": 32,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_-]*$",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id"
      ],
      "title": "OwnerReference",
      "type": "object"
    },
    "ResourceMetadata": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Annotations",
          "type": "object"
        },
        "description": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
          "title": "Id",
          "type": "string"
        },
        "labels": {
          "additionalProperties": {
            "type": "string"
          },
          "maxProperties": 32,
          "title": "Labels",
          "type": "object"
        },
        "name": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "namespace": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Namespace"
        },
        "owner_ref": {
          "$ref": "#/$defs/OwnerReference"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "owner_ref"
      ],
      "title": "ResourceMetadata",
      "type": "object"
    }
  },
  "$id": "https://schemas.servicefabric.ai/v1alpha1/effect-receipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "servicefabric.ai/v1alpha1",
      "title": "Apiversion",
      "type": "string"
    },
    "kind": {
      "const": "EffectReceipt",
      "title": "Kind",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ResourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/EffectReceiptSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "ServiceFabric EffectReceipt v1alpha1",
  "type": "object"
}
