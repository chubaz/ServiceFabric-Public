{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServiceFabric ApplicationComposition Schema",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "servicefabric.local/v1"
    },
    "kind": {
      "type": "string",
      "const": "Application"
    },
    "metadata": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 63
        },
        "name": {
          "type": "string"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["modules"],
      "additionalProperties": false,
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "kind", "kit"],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
              },
              "kind": {
                "type": "string",
                "enum": ["service", "web", "worker", "job", "library"]
              },
              "kit": {
                "type": "string"
              }
            }
          }
        },
        "status": {
          "type": "string",
          "enum": ["development", "production"]
        }
      }
    }
  }
}
