{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.servicefabric.ai/local/v1/operation.schema.json",
  "title": "ServiceFabric OperationDefinition",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": { "const": "servicefabric.local/v1" },
    "kind": { "const": "OperationDefinition" },
    "metadata": {
      "type": "object", "required": ["id", "version"], "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object", "required": ["application_ref", "module_ref", "interface_ref", "bindings"],
      "additionalProperties": false,
      "properties": {
        "application_ref": { "$ref": "#/$defs/ref" },
        "module_ref": { "$ref": "#/$defs/ref" },
        "interface_ref": { "$ref": "#/$defs/ref" },
        "bindings": {
          "type": "array", "minItems": 1, "uniqueItems": true,
          "items": { "$ref": "#/$defs/httpBinding" }
        }
      }
    }
  },
  "$defs": {
    "ref": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[.-][a-z0-9]+)*$" },
    "httpBinding": {
      "type": "object", "required": ["id", "protocol", "method", "path"], "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/ref" }, "protocol": { "const": "http" },
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
        "path": { "type": "string", "pattern": "^/(?!.*//)(?!.*\\.\\.)[^?#]*$" },
        "request_schema_ref": { "$ref": "#/$defs/ref" }, "response_schema_ref": { "$ref": "#/$defs/ref" },
        "request_content_type": { "type": "string", "minLength": 1 },
        "response_content_type": { "type": "string", "minLength": 1 },
        "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 300 }
      }
    }
  }
}
