# --- Core Config ---
COMPOSE_PROJECT_NAME=service_fabric_dev
PROXY_PORT=80
DEBUG=1
ALLOWED_HOSTS=localhost, 127.0.0.1

# --- Django Config ---
SECRET_KEY=dev_secret_key_change_me
DJANGO_SECRET_KEY=dev_secret_key_change_me

# --- Database Config ---
POSTGRES_DB=servicefabric
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/servicefabric

# --- Superuser Config ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=adminpassword

# --- Paths & Services ---
SERVICE_CATALOG_PATH=/app/services_catalog
STATIC_ASSETS_PATH=/app/flask_static
FLASK_SERVICE_URL=http://core_flask_service:5000
DJANGO_SERVICE_URL=http://backend_api:8000
REDIS_URL=redis://redis:6379/0
DJANGO_JWT_ISSUER=servicefabric-development
DJANGO_JWT_AUDIENCE=servicefabric-development
DJANGO_JWT_TOKEN_TYPE=access
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_PATH=/

# --- Flask Legacy Containment (explicit development opt-ins) ---
FLASK_ENVIRONMENT=development
ENABLE_DYNAMIC_SERVICE_IMPORTS=true
ENABLE_GENERATED_SERVICE_IMPORTS=false
ENABLE_LEGACY_FAAS_EXECUTION=false
ENABLE_INTERNAL_RELOAD=false
ENABLE_DEBUG_ROUTES=false
LEGACY_CATALOG_ALLOWLIST=
INTERNAL_RELOAD_ALLOWED_SERVICES=fabric_watcher
INTERNAL_RELOAD_ALLOWED_TARGETS=
INTERNAL_RELOAD_TOKEN=replace_with_a_development_reload_secret
ENABLE_WATCHER_RELOAD=false
WATCHER_SERVICE_ID=fabric_watcher
MAX_UPLOAD_BYTES=10485760
UPLOAD_ALLOWED_EXTENSIONS=csv,json,jpeg,jpg,pdf,png,txt

# --- FastAPI Security (deterministic local/test identity only) ---
FABRIC_ENVIRONMENT=development
JWT_SECRET_KEY=servicefabric-development-jwt-secret-not-for-production
JWT_ALGORITHM=HS256
JWT_ISSUER=servicefabric-development
JWT_AUDIENCE=servicefabric-fastapi-development
JWT_TOKEN_TYPE=fabric_internal
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
MAX_REQUEST_BODY_BYTES=1048576
MAX_VECTOR_DOCUMENTS=100
MAX_VECTOR_DOCUMENT_CHARS=20000
MAX_VECTOR_METADATA_BYTES=8192
MAX_VECTOR_TOP_K=25

# --- AI API Keys ---
GEMINI_API_KEY=
OPENAI_API_KEY=
VITE_GEMINI_API_KEY=
MISTRAL_API_KEY=
